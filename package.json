{
  "name": "nidos-gaming-stack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/astro.mjs dev",
    "build": "npm run check && node scripts/astro.mjs build",
    "preview": "node scripts/astro.mjs preview",
    "check": "npm run check:i18n && node scripts/astro.mjs check",
    "check:i18n": "node --experimental-strip-types scripts/check-i18n.ts",
    "sync:ti-assets": "node scripts/sync-ti-assets.mjs",
    "assets:import": "node scripts/import-ti-assets.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.0",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^5.9.0",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.3"
  }
}
