---
import type { DownloadFile, GameRelease } from "@/data/downloads";
import type { Locale } from "@/data/site";

interface Props {
  file: DownloadFile;
  release: GameRelease;
  locale: Locale;
}

const { file, release, locale } = Astro.props;
const labels = {
  version: locale === "zh-CN" ? "版本" : "Version",
  date: locale === "zh-CN" ? "日期" : "Date",
  size: locale === "zh-CN" ? "大小" : "Size",
  checksum: locale === "zh-CN" ? "校验" : "Checksum",
  global: locale === "zh-CN" ? "Global Mirror" : "Global Mirror",
  china: locale === "zh-CN" ? "China Mirror" : "China Mirror",
  unavailable: locale === "zh-CN" ? "暂未开放" : "Not available yet",
};
---

<article class="rounded-[22px] border border-line bg-panel p-5 shadow-sm">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h3 class="text-2xl font-semibold">{file.platform}</h3>
      <p class="mt-2 break-all text-sm text-muted">{file.filename}</p>
    </div>
    <span class="rounded-full bg-ink px-3 py-1 text-xs font-semibold text-white">{release.channel}</span>
  </div>
  <dl class="mt-5 grid gap-3 text-sm">
    <div class="flex justify-between gap-4 border-t border-line pt-3">
      <dt class="text-muted">{labels.version}</dt>
      <dd class="font-medium">{release.version}</dd>
    </div>
    <div class="flex justify-between gap-4 border-t border-line pt-3">
      <dt class="text-muted">{labels.date}</dt>
      <dd class="font-medium">{release.displayDate[locale]}</dd>
    </div>
    <div class="flex justify-between gap-4 border-t border-line pt-3">
      <dt class="text-muted">{labels.size}</dt>
      <dd class="font-medium">{file.size}</dd>
    </div>
    <div class="grid gap-1 border-t border-line pt-3">
      <dt class="text-muted">{labels.checksum}</dt>
      <dd class="break-all font-mono text-xs text-ink">{file.sha256}</dd>
    </div>
  </dl>
  <div class="mt-5 grid gap-2 sm:grid-cols-2">
    <a class:list={["rounded-full px-4 py-2 text-center text-sm font-semibold", file.available ? "bg-ink text-white" : "pointer-events-none bg-line text-muted"]} href={file.globalMirror}>
      {file.available ? labels.global : labels.unavailable}
    </a>
    <a class:list={["rounded-full px-4 py-2 text-center text-sm font-semibold", file.available ? "border border-line bg-white text-ink" : "pointer-events-none border border-line text-muted"]} href={file.chinaMirror}>
      {file.available ? labels.china : labels.unavailable}
    </a>
  </div>
</article>
