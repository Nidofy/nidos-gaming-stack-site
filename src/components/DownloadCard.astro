---
import type { DownloadFile, GameRelease } from "@/data/downloads";
import type { Locale } from "@/data/site";
import { getLocalized, t } from "@/i18n/utils";

interface Props {
  file: DownloadFile;
  release: GameRelease;
  locale: Locale;
}

const { file, release, locale } = Astro.props;
const mirrors = [
  { href: file.globalMirror, label: t(locale, "download.globalMirror"), filename: file.globalFilename ?? file.filename, variant: "primary" },
  { href: file.chinaMirror, label: t(locale, "download.chinaMirror"), filename: file.chinaFilename ?? file.filename, variant: "secondary" },
].filter((mirror) => mirror.href);
const mirrorFilenames = mirrors.map((mirror) => mirror.filename).filter(Boolean);
const hasDifferentMirrorFilenames = new Set(mirrorFilenames).size > 1;
const guideHref =
  locale === "zh-CN"
    ? "/zh-CN/guides/ti-simulator"
    : "/en/guides/ti-simulator";
---

<article class="rounded-[22px] border border-line bg-panel p-5 shadow-sm">
  <div class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-x-3 gap-y-2">
    <div class="min-w-0">
      <h3 class="text-2xl font-semibold">{getLocalized(file.displayName, locale)}</h3>
    </div>
    <span class="rounded-full bg-ink px-3 py-1 text-xs font-semibold text-white">{release.channel}</span>
    <p class="col-span-2 break-all text-sm text-muted">
      {hasDifferentMirrorFilenames ? t(locale, "download.mirrorFilenameNote") : file.filename}
    </p>
  </div>
  <dl class="mt-5 grid gap-3 text-sm">
    <div class="flex justify-between gap-4 border-t border-line pt-3">
      <dt class="text-muted">{t(locale, "download.version")}</dt>
      <dd class="break-all text-right font-medium">{release.version}</dd>
    </div>
    <div class="flex justify-between gap-4 border-t border-line pt-3">
      <dt class="text-muted">{t(locale, "download.date")}</dt>
      <dd class="text-right font-medium">{release.displayDate[locale]}</dd>
    </div>
    {file.size && (
      <div class="flex justify-between gap-4 border-t border-line pt-3">
        <dt class="text-muted">{t(locale, "download.size")}</dt>
        <dd class="font-medium">{file.size}</dd>
      </div>
    )}
    {file.sha256 && (
      <div class="grid gap-1 border-t border-line pt-3">
        <dt class="text-muted">{t(locale, "download.checksum")}</dt>
        <dd class="break-all font-mono text-xs text-ink">{file.sha256}</dd>
      </div>
    )}
  </dl>
  {
    file.available && mirrors.length > 0 ? (
      <>
        <div class:list={["mt-5 grid gap-2", mirrors.length > 1 && "sm:grid-cols-2"]}>
          {mirrors.map((mirror) => (
            <a
              class:list={[
                "rounded-full px-4 py-2 text-center text-sm font-semibold",
                mirror.variant === "primary" ? "bg-ink text-white" : "border border-line bg-white text-ink",
              ]}
              href={mirror.href}
              target="_blank"
              rel="noreferrer"
            >
              {mirror.label}
            </a>
          ))}
        </div>
        {mirrorFilenames.length > 0 && (
          <dl class="mt-4 grid gap-2 rounded-2xl border border-line bg-white p-4 text-sm">
            {mirrors.map((mirror) => (
              <div class="grid gap-1">
                <dt class="font-semibold text-ink">{mirror.label}</dt>
                <dd class="break-all text-muted">{mirror.filename}</dd>
              </div>
            ))}
          </dl>
        )}
        <div class="mt-5 rounded-2xl border border-line bg-paper p-4">
          <p class="text-sm font-semibold text-ink">{t(locale, "download.playGuideTitle")}</p>
          <p class="mt-2 text-sm leading-6 text-muted">{t(locale, "download.playGuideBody")}</p>
          <ul class="mt-3 space-y-2 text-sm leading-6 text-muted">
            <li>• {t(locale, "download.playGuideStepVerify")}</li>
            <li>• {t(locale, "download.playGuideStepExtract")}</li>
            <li>• {t(locale, "download.playGuideStepStart")}</li>
          </ul>
          <a
            class="mt-4 inline-flex rounded-full border border-line bg-white px-4 py-2 text-sm font-semibold text-ink"
            href={guideHref}
            target="_blank"
            rel="noreferrer"
          >
            {t(locale, "download.playGuideCta")}
          </a>
        </div>
      </>
    ) : (
      <div class="mt-5 rounded-2xl border border-dashed border-line bg-paper p-4">
        <p class="text-sm font-semibold text-ink">{t(locale, "download.comingSoon")}</p>
        <p class="mt-2 text-sm leading-6 text-muted">{t(locale, "download.unavailableNote")}</p>
      </div>
    )
  }
</article>
