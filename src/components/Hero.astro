---
import CTAButton from "@/components/CTAButton.astro";
import type { Locale } from "@/data/site";
import { t } from "@/i18n/utils";

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  primaryLabel: string;
  primaryHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  placeholderLabel: string;
  placeholderNote: string;
  metaItems?: string[];
  previewLabel?: string;
  assetPolicyLabel?: string;
  locale?: Locale;
  imageSrc?: string;
  imageAlt?: string;
  imageDisclaimer?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  primaryLabel,
  primaryHref,
  secondaryLabel,
  secondaryHref,
  placeholderLabel,
  placeholderNote,
  metaItems = [],
  locale = "en",
  previewLabel = t(locale, "home.hero.previewLabel"),
  assetPolicyLabel = t(locale, "home.hero.assetPolicyLabel"),
  imageSrc,
  imageAlt = "",
  imageDisclaimer,
} = Astro.props;
---

<section class="container-page pt-20 pb-14 text-center md:pt-28 md:pb-16">
  <p class="eyebrow">{eyebrow}</p>
  <h1 class="balance mx-auto mt-5 max-w-4xl text-4xl font-semibold leading-[1.12] tracking-normal sm:text-5xl lg:text-6xl">{title}</h1>
  <p class="balance mx-auto mt-6 max-w-3xl text-lg leading-8 text-muted md:text-xl md:leading-9">{subtitle}</p>
  {
    metaItems.length > 0 && (
      <div class="mx-auto mt-7 flex max-w-3xl flex-wrap justify-center gap-2">
        {metaItems.map((item) => (
          <span class="rounded-full border border-line bg-white/78 px-3 py-1.5 text-sm font-medium text-muted shadow-sm">{item}</span>
        ))}
      </div>
    )
  }
  <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row sm:flex-wrap">
    <CTAButton href={primaryHref} label={primaryLabel} />
    {secondaryLabel && secondaryHref && <CTAButton href={secondaryHref} label={secondaryLabel} variant="secondary" />}
  </div>
  {
    imageSrc ? (
      <figure class="relative mt-12 overflow-hidden rounded-[28px] border border-line bg-panel text-left shadow-soft md:mt-12">
        <img src={imageSrc} alt={imageAlt} loading="eager" class="w-full bg-paper object-contain" />
        {imageDisclaimer && (
          <figcaption class="absolute bottom-3 right-3 max-w-[72%] rounded-full bg-white/82 px-3 py-1 text-[11px] font-medium text-muted shadow-sm backdrop-blur">
            {imageDisclaimer}
          </figcaption>
        )}
      </figure>
    ) : (
      <div class="media-placeholder mt-12 overflow-hidden p-4 text-left md:mt-12 md:p-6">
        <div class="flex h-full min-h-[inherit] flex-col justify-between rounded-[22px] border border-white/70 bg-white/50 p-4 backdrop-blur md:p-6">
          <div class="flex items-center justify-between gap-4 text-xs font-semibold uppercase text-muted">
            <span>{previewLabel}</span>
            <span>{assetPolicyLabel}</span>
          </div>
          <div class="mx-auto grid w-full max-w-3xl gap-3 py-12 md:py-20">
            <div class="h-3 w-28 rounded-full bg-ink/15"></div>
            <div class="h-8 max-w-xl rounded-full bg-ink/12"></div>
            <div class="h-8 max-w-2xl rounded-full bg-ink/10"></div>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="h-24 rounded-2xl border border-line/70 bg-white/70"></div>
              <div class="h-24 rounded-2xl border border-line/70 bg-white/70"></div>
              <div class="h-24 rounded-2xl border border-line/70 bg-white/70"></div>
            </div>
          </div>
          <div class="max-w-xl rounded-2xl border border-line bg-white/84 p-5 shadow-soft">
            <p class="text-sm font-semibold text-ink">{placeholderLabel}</p>
            <p class="mt-2 text-sm leading-6 text-muted">{placeholderNote}</p>
          </div>
        </div>
      </div>
    )
  }
</section>
