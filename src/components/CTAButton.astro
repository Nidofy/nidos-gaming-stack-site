---
interface Props {
  href: string;
  label: string;
  variant?: "primary" | "secondary" | "ghost";
  compact?: boolean;
}

const { href, label, variant = "primary", compact = false } = Astro.props;
const base =
  "inline-flex items-center justify-center rounded-full font-semibold transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent";
const sizes = compact ? "px-4 py-2 text-sm" : "px-6 py-3 text-base shadow-sm";
const variants = {
  primary: "bg-ink text-white hover:bg-ink/88",
  secondary: "border border-line bg-white/82 text-ink hover:border-ink/30 hover:bg-white",
  ghost: "text-ink hover:text-accent",
};
---

<a class={`${base} ${sizes} ${variants[variant]}`} href={href}>{label}</a>
