---
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";
import { navItems, site, type Locale } from "@/data/site";
import { t } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-line/70 bg-white/86 backdrop-blur-xl">
  <div class="container-page flex min-h-16 items-center justify-between gap-3 py-3 md:py-0">
    <a class="flex min-w-0 items-center gap-3 font-semibold" href={locale === "zh-CN" ? "/zh-CN" : "/en"} aria-label={site.name[locale]}>
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-xl bg-ink text-sm text-white">N</span>
      <span class="truncate">{site.name[locale]}</span>
    </a>
    <div class="flex items-center gap-3">
      <nav class="hidden items-center gap-6 text-sm text-muted md:flex" aria-label={t(locale, "nav.mainAria")}>
        {navItems[locale].map((item) => <a class="transition hover:text-ink" href={item.href}>{item.label}</a>)}
      </nav>
      <LanguageSwitcher locale={locale} />
    </div>
  </div>
  <nav class="container-page flex gap-2 overflow-x-auto pb-3 text-sm text-muted md:hidden" aria-label={t(locale, "nav.mobileMainAria")}>
    {navItems[locale].map((item) => <a class="shrink-0 rounded-full border border-line bg-white/78 px-3 py-2 transition hover:text-ink" href={item.href}>{item.label}</a>)}
  </nav>
</header>
