---
import FeatureGrid from "@/components/FeatureGrid.astro";
import type { GameContent } from "@/data/games";
import type { GamePreviewMedia } from "@/data/media";

interface Props {
  game: GameContent;
  media: GamePreviewMedia;
}

const { game, media } = Astro.props;
const gallery = media.gallery;
---

<section class="bg-white py-20 md:py-28">
  <div class="container-page">
    <div class="mx-auto mb-12 max-w-4xl text-center">
      <p class="eyebrow">{gallery?.eyebrow ?? game.statusLabel}</p>
      <h2 class="balance mt-4 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">{gallery?.title ?? game.hero.title}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-muted">{gallery?.description ?? game.description}</p>
    </div>

    <article class="overflow-hidden rounded-lg border border-line bg-panel shadow-soft">
      <div class="bg-ink p-2">
        <img src={media.hero} alt={media.alt} loading="lazy" class="aspect-[3/2] w-full rounded-md bg-paper object-cover" />
      </div>
      <div class="grid gap-5 p-6 md:grid-cols-[0.9fr_1.1fr] md:p-8">
        <div>
          <p class="eyebrow">{game.statusLabel}</p>
          <h3 class="mt-3 text-2xl font-semibold md:text-3xl">{game.title}</h3>
        </div>
        <p class="leading-7 text-muted">{game.description}</p>
      </div>
    </article>

    <div class="mt-12">
      <FeatureGrid features={game.features} />
    </div>

    {
      gallery && (
        <div class="mt-14 grid gap-5 md:grid-cols-3">
          {gallery.images.map((image) => (
            <figure class="overflow-hidden rounded-lg border border-line bg-panel shadow-sm">
              <img src={image.src} alt={image.alt} loading="lazy" class="aspect-[3/2] w-full bg-paper object-cover" />
              <figcaption class="p-5">
                <p class="eyebrow">{game.shortTitle}</p>
                <h4 class="mt-2 text-xl font-semibold">{image.caption}</h4>
              </figcaption>
            </figure>
          ))}
        </div>
      )
    }

    <div class="mt-14 grid gap-6 md:grid-cols-2">
      {game.sections.map((section) => (
        <article class="border-t border-line pt-8">
          <h3 class="text-2xl font-semibold sm:text-3xl">{section.title}</h3>
          <p class="mt-4 leading-8 text-muted">{section.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
