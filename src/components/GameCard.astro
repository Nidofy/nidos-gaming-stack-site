---
import CTAButton from "@/components/CTAButton.astro";
import type { GameContent } from "@/data/games";
import { t } from "@/i18n/utils";

interface Props {
  game: GameContent;
  imageSrc?: string;
  imageAlt?: string;
  imageDisclaimer?: string;
}

const { game, imageSrc, imageAlt = "", imageDisclaimer } = Astro.props;
---

<article class="grid gap-8 rounded-[28px] border border-line bg-panel p-6 shadow-soft md:grid-cols-[0.9fr_1.1fr] md:p-8">
  {
    imageSrc ? (
      <figure class="relative min-h-[260px] overflow-hidden rounded-[22px] border border-line bg-paper">
        <img src={imageSrc} alt={imageAlt} loading="lazy" class="h-full min-h-[260px] w-full object-contain" />
        {imageDisclaimer && <figcaption class="absolute bottom-3 right-3 rounded-full bg-white/82 px-3 py-1 text-[11px] font-medium text-muted shadow-sm backdrop-blur">{imageDisclaimer}</figcaption>}
      </figure>
    ) : (
      <div class="media-placeholder min-h-[260px] rounded-[22px] p-5">
        <div class="flex h-full items-end">
          <p class="rounded-2xl bg-white/82 p-4 text-sm leading-6 text-muted">{game.hero.placeholderLabel}</p>
        </div>
      </div>
    )
  }
  <div class="flex flex-col justify-center">
    <p class="eyebrow">{game.statusLabel}</p>
    <h3 class="mt-3 text-3xl font-semibold md:text-4xl">{game.title}</h3>
    <p class="mt-4 text-lg leading-8 text-muted">{game.summary}</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {game.tags.map((tag) => <span class="rounded-full border border-line px-3 py-1 text-sm text-muted">{tag}</span>)}
    </div>
    <div class="mt-7 flex flex-wrap gap-3">
      <CTAButton href={game.primaryCta.href} label={game.primaryCta.label} compact />
      <CTAButton href={`/${game.locale}/games/${game.slug}`} label={t(game.locale, "game.detailsCta")} variant="secondary" compact />
    </div>
  </div>
</article>
