---
import { existsSync, readFileSync } from "node:fs";
import { join } from "node:path";
import type { Locale } from "@/data/site";
import { t } from "@/i18n/utils";

interface Props {
  locale: Locale;
}

type ExportedAsset = {
  id?: string;
  filename?: string;
  sourcePath: string;
  type: string;
  role: string;
  title: string;
  alt: string;
  recommendedAltText?: string;
  description: string;
  websiteUsage?: string;
  width?: number;
  height?: number;
};

type ExportManifest = {
  schemaVersion: number;
  project: string;
  generatedAt: string;
  assets: ExportedAsset[];
};

type GalleryLabelKey = "decision" | "strategy" | "achievement" | "summary" | "fallback";

type GalleryAsset = {
  id: string;
  labelKey: GalleryLabelKey;
  asset: ExportedAsset;
};

const gameplayAssetIds = ["hero-gameplay", "decision-screen", "strategy-map", "achievement-screen", "match-summary"] as const;
type GameplayAssetId = (typeof gameplayAssetIds)[number];
const gameplayAssetIdSet = new Set<string>(gameplayAssetIds);
const localizedAssetCopy: Record<Locale, Record<GameplayAssetId, { title: string; description: string }>> = {
  "zh-CN": {
    "hero-gameplay": {
      title: "玩法总览截图",
      description: "展示 TI 模拟器从赛程推进、比赛状态到关键决策的整体玩法印象。",
    },
    "decision-screen": {
      title: "决策界面",
      description: "展示检查点选择、风险收益提示，以及安全、均衡、冒险三类行动思路。",
    },
    "strategy-map": {
      title: "战术地图",
      description: "展示兵线、目标压力和队伍站位，让玩家快速判断下一步的宏观策略。",
    },
    "achievement-screen": {
      title: "成就解锁",
      description: "展示本地档案、阶段目标和游玩进度，帮助一局比赛形成可追踪的成长反馈。",
    },
    "match-summary": {
      title: "赛后总结",
      description: "展示比分、关键选手和赛后报告，把一局幻想赛事整理成清晰的复盘结果。",
    },
  },
  en: {
    "hero-gameplay": {
      title: "Gameplay overview",
      description: "Shows the broad match-flow concept across schedule progress, match state, and key decisions.",
    },
    "decision-screen": {
      title: "Decision screen",
      description: "Shows checkpoint choices, risk-reward hints, and safe, balanced, or risky tactical options.",
    },
    "strategy-map": {
      title: "Tactical map",
      description: "Shows lane pressure, objective state, and team positioning for macro planning.",
    },
    "achievement-screen": {
      title: "Achievement unlock",
      description: "Shows local profile progress, milestone goals, and progression feedback.",
    },
    "match-summary": {
      title: "Match summary",
      description: "Shows score, key performers, and postgame report panels for a clear match recap.",
    },
  },
};
localizedAssetCopy["zh-CN"] = {
  "hero-gameplay": {
    title: "玩法总览截图",
    description: "展示 TI 模拟器从赛程推进、比赛状态到关键决策的整体玩法印象。",
  },
  "decision-screen": {
    title: "决策界面",
    description: "展示检查点选择、风险收益提示，以及安全、均衡、冒险三类行动思路。",
  },
  "strategy-map": {
    title: "战术地图",
    description: "展示兵线、目标压力和队伍站位，让玩家快速判断下一步的宏观策略。",
  },
  "achievement-screen": {
    title: "成就解锁",
    description: "展示本地档案、阶段目标和游玩进度，帮助一局比赛形成可追踪的成长反馈。",
  },
  "match-summary": {
    title: "赛后总结",
    description: "展示比分、关键选手和赛后报告，把一局幻想赛事整理成清晰的复盘结果。",
  },
};
const manifestPath = join(process.cwd(), "public", "generated", "ti-simulator", "manifest.json");
const assetBase = "/generated/ti-simulator";
const { locale } = Astro.props;
let manifest: ExportManifest | null = null;

if (existsSync(manifestPath)) {
  try {
    const parsed = JSON.parse(readFileSync(manifestPath, "utf8")) as Partial<ExportManifest>;
    if (parsed.project === "ti-simulator" && Array.isArray(parsed.assets)) {
      manifest = {
        schemaVersion: Number(parsed.schemaVersion ?? 1),
        project: parsed.project,
        generatedAt: String(parsed.generatedAt ?? ""),
        assets: parsed.assets
          .filter((asset) => asset && typeof asset.sourcePath === "string")
          .map((asset) => ({
            id: String(asset.id ?? ""),
            filename: String(asset.sourcePath),
            sourcePath: String(asset.sourcePath),
            type: String(asset.type ?? ""),
            role: String(asset.websiteUsage ?? asset.id ?? "preview"),
            title: String(asset.title ?? asset.id ?? "TI Simulator asset"),
            alt: String(asset.recommendedAltText ?? asset.title ?? "TI Simulator preview asset"),
            recommendedAltText: String(asset.recommendedAltText ?? ""),
            description: String(asset.description ?? ""),
            websiteUsage: String(asset.websiteUsage ?? ""),
          })),
      };
    }
  } catch {
    manifest = null;
  }
}

const imageAssets = manifest?.assets.filter((asset) => asset.type.startsWith("image/")) ?? [];
const byId = new Map(imageAssets.map((asset) => [asset.id, asset]));
const screenshotAssets = imageAssets.filter((asset) => gameplayAssetIdSet.has((asset.id ?? "").replace(/-en$/, "")));
const getLocalizedAsset = (id: GameplayAssetId) => {
  if (locale === "en") return byId.get(`${id}-en`) ?? byId.get(id);
  return byId.get(id) ?? byId.get(`${id}-en`);
};
const previewAsset = getLocalizedAsset("hero-gameplay") ?? screenshotAssets[0];
const featureAssets: ReadonlyArray<{ id: GameplayAssetId; labelKey: GalleryLabelKey }> = [
  { id: "decision-screen", labelKey: "decision" },
  { id: "strategy-map", labelKey: "strategy" },
  { id: "achievement-screen", labelKey: "achievement" },
  { id: "match-summary", labelKey: "summary" },
];
const visibleFeatureAssets: GalleryAsset[] = featureAssets.flatMap((item) => {
    const asset = getLocalizedAsset(item.id);
    return asset ? [{ id: item.id, labelKey: item.labelKey, asset }] : [];
  });
const fallbackFeatureAssets: GalleryAsset[] = screenshotAssets
  .filter((asset) => asset.sourcePath !== previewAsset?.sourcePath)
  .slice(0, 4)
  .map((asset, index) => ({
    id: asset.id || `preview-${index}`,
    labelKey: "fallback" as const,
    asset,
  }));
const galleryAssets = visibleFeatureAssets.length > 0 ? visibleFeatureAssets : fallbackFeatureAssets;

const imageSrc = (asset: ExportedAsset) => `${assetBase}/${asset.sourcePath}`;
const imageAlt = (asset: ExportedAsset) => asset.recommendedAltText || asset.alt || asset.title;
const assetBaseId = (asset: ExportedAsset) => (asset.id ?? "").replace(/-en$/, "") as GameplayAssetId;
const assetTitle = (asset: ExportedAsset) => localizedAssetCopy[locale][assetBaseId(asset)]?.title ?? asset.title;
const assetDescription = (asset: ExportedAsset) => localizedAssetCopy[locale][assetBaseId(asset)]?.description ?? asset.description;
const galleryLabel = (labelKey: GalleryLabelKey) => t(locale, `tiAssets.${labelKey}`);
---

<section class="bg-white py-20 md:py-28">
  <div class="container-page">
    <div class="mx-auto mb-12 max-w-4xl text-center">
      <p class="eyebrow">{t(locale, "tiAssets.eyebrow")}</p>
      <h2 class="balance mt-4 text-3xl font-semibold tracking-tight sm:text-4xl lg:text-5xl">{t(locale, "tiAssets.title")}</h2>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-8 text-muted">
        {t(locale, "tiAssets.intro")}
      </p>
    </div>

    {
      screenshotAssets.length > 0 ? (
        <div class="space-y-10">
          {previewAsset && (
            <article class="overflow-hidden rounded-lg border border-line bg-panel shadow-soft">
              <div class="bg-ink p-2">
                <img
                  src={imageSrc(previewAsset)}
                  alt={imageAlt(previewAsset)}
                  loading="lazy"
                  class="aspect-[16/9] w-full rounded-md bg-paper object-cover"
                />
              </div>
              <div class="grid gap-5 p-6 md:grid-cols-[1fr_1.5fr] md:p-8">
                <div>
                  <p class="eyebrow">{t(locale, "tiAssets.heroLabel")}</p>
                  <h3 class="mt-3 text-2xl font-semibold md:text-3xl">{assetTitle(previewAsset)}</h3>
                </div>
                <p class="leading-7 text-muted">{assetDescription(previewAsset)}</p>
              </div>
            </article>
          )}

          {galleryAssets.length > 0 && (
            <div class="grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
              <div class="lg:sticky lg:top-8">
                <p class="eyebrow">{t(locale, "tiAssets.heroKicker")}</p>
                <h3 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">{t(locale, "tiAssets.galleryTitle")}</h3>
                <p class="mt-4 leading-7 text-muted">{t(locale, "tiAssets.galleryIntro")}</p>
              </div>

              <div class="grid gap-5 md:grid-cols-2">
                {galleryAssets.map(({ asset, labelKey }) => (
                  <figure class="overflow-hidden rounded-lg border border-line bg-panel shadow-sm">
                    <img
                      src={imageSrc(asset)}
                      alt={imageAlt(asset)}
                      loading="lazy"
                      class="aspect-[16/10] w-full bg-paper object-cover"
                    />
                    <figcaption class="p-5">
                      <p class="eyebrow">{galleryLabel(labelKey)}</p>
                      <h4 class="mt-2 text-xl font-semibold">{assetTitle(asset)}</h4>
                      <p class="mt-3 text-sm leading-6 text-muted">{assetDescription(asset)}</p>
                    </figcaption>
                  </figure>
                ))}
              </div>
            </div>
          )}
        </div>
      ) : (
        <div class="mx-auto max-w-3xl rounded-lg border border-dashed border-line bg-panel p-8 text-center">
          <p class="eyebrow">{t(locale, "tiAssets.emptyEyebrow")}</p>
          <h3 class="mt-3 text-2xl font-semibold">{t(locale, "tiAssets.emptyTitle")}</h3>
          <p class="mx-auto mt-3 max-w-2xl leading-7 text-muted">
            {t(locale, "tiAssets.emptyBody")}
          </p>
        </div>
      )
    }
  </div>
</section>
