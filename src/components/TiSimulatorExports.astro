---
import { existsSync, readFileSync } from "node:fs";
import { join } from "node:path";
import type { Locale } from "@/data/site";

interface Props {
  locale: Locale;
}

type ExportedAsset = {
  filename: string;
  type: string;
  role: string;
  title: string;
  alt: string;
  description: string;
  width?: number;
  height?: number;
};

type ExportManifest = {
  schemaVersion: number;
  project: string;
  generatedAt: string;
  assets: ExportedAsset[];
};

const manifestPath = join(process.cwd(), "public", "generated", "ti-simulator", "asset-manifest.json");
const assetBase = "/generated/ti-simulator";
const { locale } = Astro.props;
let manifest: ExportManifest | null = null;

if (existsSync(manifestPath)) {
  try {
    const parsed = JSON.parse(readFileSync(manifestPath, "utf8")) as Partial<ExportManifest>;
    if (parsed.project === "ti-simulator" && Array.isArray(parsed.assets)) {
      manifest = {
        schemaVersion: Number(parsed.schemaVersion ?? 1),
        project: parsed.project,
        generatedAt: String(parsed.generatedAt ?? ""),
        assets: parsed.assets.filter((asset) => asset && typeof asset.filename === "string") as ExportedAsset[],
      };
    }
  } catch {
    manifest = null;
  }
}

const visibleAssets = manifest?.assets.slice(0, 3) ?? [];
const copy = {
  "zh-CN": {
    eyebrow: "Generated Media",
    title: "来自模拟器项目的站点素材。",
    intro: "网站会消费从 TI 模拟器项目复制过来的导出资源。资源缺失时，这个区块会自动降级，不阻塞网站构建。",
    emptyEyebrow: "No export found",
    emptyTitle: "还没有导入 TI 模拟器生成素材。",
    emptyBody: "先在模拟器项目生成站点素材，再运行网站导入脚本。导入前，网站仍可独立构建和运行。",
  },
  en: {
    eyebrow: "Generated Media",
    title: "Simulator exports for the website.",
    intro: "The website consumes a copied export bundle from the TI Simulator project. If the bundle is absent, this section falls back without blocking the build.",
    emptyEyebrow: "No export found",
    emptyTitle: "Generated TI Simulator assets are not imported yet.",
    emptyBody: "Run the simulator export and website import scripts to populate this area. Until then, the website remains independently runnable.",
  },
}[locale];
---

<section class="bg-white/70 py-20">
  <div class="container-page">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="eyebrow">{copy.eyebrow}</p>
        <h2 class="mt-3 text-4xl font-semibold md:text-5xl">{copy.title}</h2>
      </div>
      <p class="max-w-xl leading-7 text-muted">
        {copy.intro}
      </p>
    </div>

    {
      visibleAssets.length > 0 ? (
        <div class="grid gap-4 lg:grid-cols-3">
          {visibleAssets.map((asset) => (
            <article class="overflow-hidden rounded-lg border border-line bg-panel shadow-sm">
              <img
                src={`${assetBase}/${asset.filename}`}
                alt={asset.alt}
                width={asset.width}
                height={asset.height}
                loading="lazy"
                class="aspect-[16/10] w-full bg-paper object-cover"
              />
              <div class="p-5">
                <p class="eyebrow">{asset.role}</p>
                <h3 class="mt-2 text-xl font-semibold">{asset.title}</h3>
                <p class="mt-3 leading-7 text-muted">{asset.description}</p>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-line bg-panel p-8">
          <p class="eyebrow">{copy.emptyEyebrow}</p>
          <h3 class="mt-3 text-2xl font-semibold">{copy.emptyTitle}</h3>
          <p class="mt-3 max-w-2xl leading-7 text-muted">
            {copy.emptyBody}
          </p>
        </div>
      )
    }
  </div>
</section>
