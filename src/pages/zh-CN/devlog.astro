---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/utils";

const locale = "zh-CN";
---

<BaseLayout locale={locale} title={t(locale, "devlog.title")} description={t(locale, "devlog.description")}>
  <section class="container-page section-space">
    <p class="eyebrow">{t(locale, "devlog.eyebrow")}</p>
    <h1 class="mt-4 text-4xl font-semibold sm:text-5xl lg:text-6xl">{t(locale, "devlog.heading")}</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">{t(locale, "devlog.intro")}</p>
  </section>
  <section class="container-page pb-24">
    <article class="rounded-[24px] border border-dashed border-line bg-white/68 p-8">
      <p class="eyebrow">{t(locale, "devlog.todoEyebrow")}</p>
      <h2 class="mt-3 text-3xl font-semibold">{t(locale, "devlog.todoTitle")}</h2>
      <p class="mt-4 leading-8 text-muted">{t(locale, "devlog.todoBody")}</p>
    </article>
  </section>
</BaseLayout>
