---
import DownloadCard from "@/components/DownloadCard.astro";
import CTAButton from "@/components/CTAButton.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestRelease } from "@/data/downloads";
import { getGame } from "@/data/games";
import { tiSimulatorPreviewMedia } from "@/data/media";
import { getFeedbackLink } from "@/data/social";
import { t } from "@/i18n/utils";

const locale = "zh-CN";
const game = getGame(locale, "ti-simulator");
const release = getLatestRelease("ti-simulator");
if (!game || !release) throw new Error("Missing download data.");
const feedbackLink = getFeedbackLink(locale);
const previewMedia = tiSimulatorPreviewMedia[locale];
---

<BaseLayout locale={locale} title={t(locale, "download.title")} description={t(locale, "download.description")} ogImage={previewMedia.og}>
  <section class="container-page section-space">
    <p class="eyebrow">{t(locale, "download.eyebrow")}</p>
    <h1 class="balance mt-4 max-w-4xl text-4xl font-semibold sm:text-5xl lg:text-6xl">{t(locale, "download.heading")}</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">{release.summary[locale]}</p>
    <p class="mt-4 max-w-3xl rounded-2xl border border-dashed border-line bg-white/76 p-4 text-sm leading-6 text-muted">
      {t(locale, "download.notice")}
    </p>
  </section>

  <section class="container-page pb-16">
    <div class="grid gap-4 lg:grid-cols-3">
      {release.files.map((file) => <DownloadCard file={file} release={release} locale={locale} />)}
    </div>
  </section>

  {
    feedbackLink.available && (
      <section id="feedback-coming-soon" class="container-page pb-16">
        <div class="rounded-[24px] border border-line bg-panel p-6 shadow-sm">
          <p class="eyebrow">{t(locale, "feedback.eyebrow")}</p>
          <h2 class="mt-3 text-2xl font-semibold">{t(locale, "feedback.downloadTitle")}</h2>
          <p class="mt-3 max-w-2xl leading-7 text-muted">{t(locale, "feedback.availableBody")}</p>
          <div class="mt-5">
            <CTAButton href={feedbackLink.href} label={feedbackLink.label} variant="secondary" />
          </div>
        </div>
      </section>
    )
  }

  <section class="container-page grid gap-6 pb-24 md:grid-cols-2">
    <article class="rounded-[24px] border border-line bg-panel p-6">
      <h2 class="text-2xl font-semibold">{t(locale, "download.changelog")}</h2>
      <ul class="mt-4 space-y-3 text-muted">
        {release.changelog[locale].map((item) => <li>• {item}</li>)}
      </ul>
    </article>
    <article class="rounded-[24px] border border-line bg-panel p-6">
      <h2 class="text-2xl font-semibold">{t(locale, "download.knownIssues")}</h2>
      <ul class="mt-4 space-y-3 text-muted">
        {release.knownIssues[locale].map((item) => <li>• {item}</li>)}
      </ul>
    </article>
  </section>
</BaseLayout>
