---
import CTAButton from "@/components/CTAButton.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestRelease } from "@/data/downloads";
import { getGame } from "@/data/games";
import { getTiSimulatorWechatCover } from "@/data/media";
import { getFeedbackLink } from "@/data/social";
import { t } from "@/i18n/utils";

const locale = "zh-CN";
const game = getGame(locale, "ti-simulator");
const release = getLatestRelease("ti-simulator");
if (!game || !release) throw new Error("Missing WeChat page data.");
const feedbackLink = getFeedbackLink(locale);
const wechatCover = getTiSimulatorWechatCover(locale);
---

<BaseLayout
  locale={locale}
  title={t(locale, "wechat.title")}
  description={t(locale, "wechat.description")}
  ogImage={wechatCover}
  alternatePaths={{ "zh-CN": "/zh-CN/wechat", en: "/en" }}
>
  <section class="container-page py-12 md:py-16">
    <p class="eyebrow">{t(locale, "wechat.eyebrow")}</p>
    <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">{t(locale, "wechat.heading")}</h1>
    <p class="mt-5 text-lg leading-8 text-muted">{game.summary}</p>
    <div class="mt-7 flex flex-col gap-3 sm:flex-row">
      <CTAButton href="/zh-CN/download" label={t(locale, "wechat.downloadCta")} />
      <CTAButton href={feedbackLink.href} label={feedbackLink.label} variant="secondary" />
    </div>
  </section>

  <section class="container-page pb-10">
    <figure class="relative mx-auto max-w-xl overflow-hidden rounded-[24px] border border-line bg-panel shadow-soft">
      <img src={wechatCover} alt={t(locale, "media.tiSimulatorPreviewAlt")} loading="eager" class="max-h-[720px] w-full bg-paper object-contain" />
      <figcaption class="absolute bottom-3 right-3 max-w-[72%] rounded-full bg-white/82 px-3 py-1 text-[11px] font-medium text-muted shadow-sm backdrop-blur">
        {t(locale, "media.entertainmentDisclaimer")}
      </figcaption>
    </figure>
  </section>

  <section class="container-page grid gap-4 pb-16">
    <article class="rounded-[22px] border border-line bg-panel p-5">
      <h2 class="text-2xl font-semibold">{t(locale, "wechat.versionTitle")}</h2>
      <p class="mt-3 leading-7 text-muted">{t(locale, "wechat.versionBody", { version: release.version, date: release.displayDate[locale] })}</p>
    </article>
    <article class="rounded-[22px] border border-line bg-panel p-5">
      <h2 class="text-2xl font-semibold">{t(locale, "wechat.groupTitle")}</h2>
      <p class="mt-3 leading-7 text-muted">{t(locale, "wechat.groupBody")}</p>
    </article>
    <article id="feedback-coming-soon" class="rounded-[22px] border border-line bg-panel p-5">
      <h2 class="text-2xl font-semibold">{t(locale, "wechat.guidanceTitle")}</h2>
      <p class="mt-3 leading-7 text-muted">
        {feedbackLink.available
          ? t(locale, "wechat.guidanceAvailable")
          : t(locale, "wechat.guidanceComingSoon")}
      </p>
    </article>
  </section>
</BaseLayout>
