---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { t } from "@/i18n/utils";

const locale = "en";
---

<BaseLayout locale={locale} title={t(locale, "terms.title")} description={t(locale, "terms.description")}>
  <section class="container-page section-space">
    <p class="eyebrow">{t(locale, "terms.eyebrow")}</p>
    <h1 class="mt-4 text-4xl font-semibold sm:text-5xl lg:text-6xl">{t(locale, "terms.heading")}</h1>
    <div class="mt-8 max-w-3xl space-y-6 text-lg leading-8 text-muted">
      <section>
        <h2 class="text-2xl font-semibold text-ink">{t(locale, "terms.enHeading")}</h2>
        <p class="mt-4">{t(locale, "terms.enBody1")}</p>
        <p class="mt-4">{t(locale, "terms.enBody2")}</p>
      </section>
      <section lang="zh-CN">
        <h2 class="text-2xl font-semibold text-ink">{t(locale, "terms.zhHeading")}</h2>
        <p class="mt-4">{t(locale, "terms.zhBody1")}</p>
        <p class="mt-4">{t(locale, "terms.zhBody2")}</p>
      </section>
    </div>
  </section>
</BaseLayout>
