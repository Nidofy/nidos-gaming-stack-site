---
import CTAButton from "@/components/CTAButton.astro";
import HomeProjectTabs from "@/components/HomeProjectTabs.astro";
import TiSimulatorExports from "@/components/TiSimulatorExports.astro";
import UntitledActionRpgHomePromo from "@/components/UntitledActionRpgHomePromo.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { games } from "@/data/games";
import { getGamePreviewMedia, getHomepageOgImage } from "@/data/media";
import { site } from "@/data/site";
import { t } from "@/i18n/utils";

const locale = "en";
const homepageOgImage = getHomepageOgImage(locale);
const gameCards = games[locale].map((game) => ({
  game,
  media: getGamePreviewMedia(game.slug, locale),
}));
const tiSimulatorCard = gameCards.find(({ game }) => game.slug === "ti-simulator");
const untitledActionRpgCard = gameCards.find(({ game }) => game.slug === "untitled-action-rpg");
---

<BaseLayout
  locale={locale}
  title={`${site.name[locale]} - ${t(locale, "home.titleSuffix")}`}
  description={site.description[locale]}
  ogImage={homepageOgImage}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name[locale],
    description: site.description[locale],
    url: `${site.baseUrl}/en`,
  }}
>
  <HomeProjectTabs
    locale={locale}
    eyebrow={t(locale, "home.hero.eyebrow")}
    title={t(locale, "home.hero.title")}
    subtitle={t(locale, "home.hero.subtitle")}
    metaItems={[t(locale, "home.hero.metaFeatured"), t(locale, "home.hero.metaFuture"), t(locale, "home.hero.metaBilingual")]}
    gameCards={gameCards}
  />

  <div data-home-project-detail="ti-simulator" hidden={!tiSimulatorCard}>
    <TiSimulatorExports locale={locale} />
  </div>

  {
    untitledActionRpgCard && (
      <div data-home-project-detail="untitled-action-rpg" hidden>
        <UntitledActionRpgHomePromo game={untitledActionRpgCard.game} media={untitledActionRpgCard.media} />
      </div>
    )
  }

  <section class="container-page section-space text-center">
    <p class="eyebrow">{t(locale, "home.next.eyebrow")}</p>
    <h2 class="balance mx-auto mt-3 max-w-3xl text-3xl font-semibold sm:text-4xl md:text-5xl">{t(locale, "home.next.title")}</h2>
    <p class="mx-auto mt-5 max-w-2xl leading-8 text-muted">{t(locale, "home.next.description")}</p>
    <div class="mt-8">
      <CTAButton href="/en/download" label={t(locale, "home.next.cta")} />
    </div>
  </section>
</BaseLayout>
