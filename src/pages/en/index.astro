---
import CTAButton from "@/components/CTAButton.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import GameCard from "@/components/GameCard.astro";
import Hero from "@/components/Hero.astro";
import TiSimulatorExports from "@/components/TiSimulatorExports.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { games } from "@/data/games";
import { getHomepageOgImage, tiSimulatorPreviewMedia } from "@/data/media";
import { site } from "@/data/site";
import { t } from "@/i18n/utils";

const locale = "en";
const featuredGame = games[locale][0];
const previewMedia = tiSimulatorPreviewMedia[locale];
const previewAlt = t(locale, "media.tiSimulatorPreviewAlt");
const previewDisclaimer = t(locale, "media.entertainmentDisclaimer");
const homepageOgImage = getHomepageOgImage(locale);
---

<BaseLayout
  locale={locale}
  title={`${site.name[locale]} - ${t(locale, "home.titleSuffix")}`}
  description={site.description[locale]}
  ogImage={homepageOgImage}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name[locale],
    description: site.description[locale],
    url: `${site.baseUrl}/en`,
  }}
>
  <Hero
    locale={locale}
    eyebrow={t(locale, "home.hero.eyebrow")}
    title={t(locale, "home.hero.title")}
    subtitle={t(locale, "home.hero.subtitle")}
    primaryLabel={t(locale, "home.hero.primary")}
    primaryHref="/en/games/ti-simulator"
    secondaryLabel={t(locale, "home.hero.secondary")}
    secondaryHref="/en/download"
    placeholderLabel={t(locale, "home.hero.placeholderLabel")}
    placeholderNote={t(locale, "home.hero.placeholderNote")}
    metaItems={[t(locale, "home.hero.metaFeatured"), t(locale, "home.hero.metaFuture"), t(locale, "home.hero.metaBilingual")]}
    previewLabel={t(locale, "home.hero.previewLabel")}
    assetPolicyLabel={t(locale, "home.hero.assetPolicyLabel")}
    imageSrc={previewMedia.hero}
    imageAlt={previewAlt}
    imageDisclaimer={previewDisclaimer}
  />

  <section id="games" class="container-page section-space">
    <div class="mb-10 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="eyebrow">{t(locale, "home.games.eyebrow")}</p>
        <h2 class="mt-3 text-3xl font-semibold sm:text-4xl md:text-5xl">{t(locale, "home.games.title")}</h2>
      </div>
      <p class="max-w-xl leading-7 text-muted">{t(locale, "home.games.description")}</p>
    </div>
    <GameCard game={featuredGame} imageSrc={previewMedia.hero} imageAlt={previewAlt} imageDisclaimer={previewDisclaimer} />
  </section>

  <TiSimulatorExports locale={locale} />

  <section class="bg-white/62 py-20">
    <div class="container-page">
      <div class="mb-10 max-w-2xl">
        <p class="eyebrow">{t(locale, "home.direction.eyebrow")}</p>
        <h2 class="mt-3 text-3xl font-semibold sm:text-4xl md:text-5xl">{t(locale, "home.direction.title")}</h2>
      </div>
      <FeatureGrid
        features={[
          { title: t(locale, "home.direction.feature1.title"), description: t(locale, "home.direction.feature1.description") },
          { title: t(locale, "home.direction.feature2.title"), description: t(locale, "home.direction.feature2.description") },
          { title: t(locale, "home.direction.feature3.title"), description: t(locale, "home.direction.feature3.description") },
        ]}
      />
    </div>
  </section>

  <section class="container-page section-space text-center">
    <p class="eyebrow">{t(locale, "home.next.eyebrow")}</p>
    <h2 class="balance mx-auto mt-3 max-w-3xl text-3xl font-semibold sm:text-4xl md:text-5xl">{t(locale, "home.next.title")}</h2>
    <p class="mx-auto mt-5 max-w-2xl leading-8 text-muted">{t(locale, "home.next.description")}</p>
    <div class="mt-8">
      <CTAButton href="/en/download" label={t(locale, "home.next.cta")} />
    </div>
  </section>
</BaseLayout>
