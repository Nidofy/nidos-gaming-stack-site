---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout locale="en" title="Devlog - Nido's Gaming Stack" description="Development notes for TI Simulator and future small games from Nido's Gaming Stack.">
  <section class="container-page section-space">
    <p class="eyebrow">Devlog</p>
    <h1 class="mt-4 text-5xl font-semibold md:text-7xl">Devlog</h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">Development updates, playtest notes, design decisions, and release notes for TI Simulator and future small games.</p>
  </section>
  <section class="container-page pb-24">
    <article class="rounded-[24px] border border-dashed border-line bg-white/68 p-8">
      <p class="eyebrow">TODO</p>
      <h2 class="mt-3 text-3xl font-semibold">MDX devlog content is not connected yet.</h2>
      <p class="mt-4 leading-8 text-muted">The next step is to manage bilingual posts in `src/content/posts/` and group them by game, date, and tag.</p>
    </article>
  </section>
</BaseLayout>
