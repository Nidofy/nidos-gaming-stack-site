---
import CTAButton from "@/components/CTAButton.astro";
import FeatureGrid from "@/components/FeatureGrid.astro";
import Hero from "@/components/Hero.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getLatestRelease, type GameRelease } from "@/data/downloads";
import { games, type GameContent } from "@/data/games";
import { getGamePreviewMedia } from "@/data/media";
import { site } from "@/data/site";
import { t } from "@/i18n/utils";

type Props = {
  game: GameContent;
  release?: GameRelease;
};

export function getStaticPaths() {
  return games.en.map((game) => ({
    params: { slug: game.slug },
    props: { game, release: getLatestRelease(game.slug) },
  }));
}

const locale = "en";
const { game, release } = Astro.props;
const previewMedia = getGamePreviewMedia(game.slug, locale);
---

<BaseLayout
  locale={locale}
  title={game.seo.title}
  description={game.seo.description}
  ogImage={previewMedia.og}
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "VideoGame",
    name: game.title,
    description: game.description,
    applicationCategory: "Game",
    operatingSystem: game.platforms.join(", "),
    url: `${site.baseUrl}/en/games/${game.slug}`,
  }}
>
  <Hero
    locale={locale}
    eyebrow={game.hero.eyebrow}
    title={game.hero.title}
    subtitle={game.hero.subtitle}
    primaryLabel={game.primaryCta.label}
    primaryHref={game.primaryCta.href}
    secondaryLabel={game.secondaryCta.label}
    secondaryHref={game.secondaryCta.href}
    tertiaryLabel={release ? t(locale, "game.backToGamesCta") : undefined}
    tertiaryHref={release ? "/en/#games" : undefined}
    placeholderLabel={game.hero.placeholderLabel}
    placeholderNote={game.hero.placeholderNote}
    imageSrc={previewMedia.hero}
    imageAlt={previewMedia.alt}
    imageDisclaimer={previewMedia.disclaimer}
  />

  <section class="container-page section-space">
    <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr] md:items-start">
      <div>
        <p class="eyebrow">{game.statusLabel}</p>
        <h2 class="mt-3 text-3xl font-semibold sm:text-4xl md:text-5xl">{game.tagline}</h2>
      </div>
      <div class="text-lg leading-9 text-muted">
        <p>{game.description}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {game.platforms.map((platform) => <span class="rounded-full border border-line bg-white px-3 py-1 text-sm">{platform}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white/62 py-20">
    <div class="container-page">
      <FeatureGrid features={game.features} />
    </div>
  </section>

  {
    previewMedia.gallery && (
      <section class="container-page section-space">
        <div class="mb-10 max-w-3xl">
          <p class="eyebrow">{previewMedia.gallery.eyebrow}</p>
          <h2 class="mt-3 text-3xl font-semibold sm:text-4xl md:text-5xl">{previewMedia.gallery.title}</h2>
          <p class="mt-5 leading-8 text-muted">{previewMedia.gallery.description}</p>
        </div>
        <div class="grid gap-5 md:grid-cols-3">
          {previewMedia.gallery.images.map((image) => (
            <figure class="overflow-hidden rounded-[24px] border border-line bg-panel shadow-soft">
              <img src={image.src} alt={image.alt} loading="lazy" class="aspect-[3/2] w-full object-cover" />
              <figcaption class="px-5 py-4 text-sm font-semibold text-muted">{image.caption}</figcaption>
            </figure>
          ))}
        </div>
      </section>
    )
  }

  <section class="container-page section-space">
    <div class="grid gap-6 md:grid-cols-2">
      {game.sections.map((section) => (
        <article class="border-t border-line pt-8">
          <h3 class="text-2xl font-semibold sm:text-3xl">{section.title}</h3>
          <p class="mt-4 leading-8 text-muted">{section.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="rounded-[28px] border border-line bg-panel p-8 shadow-soft md:p-10">
      <p class="eyebrow">{release ? t(locale, "game.playtestEyebrow") : game.statusLabel}</p>
      <h2 class="mt-3 text-3xl font-semibold">
        {release ? t(locale, "game.currentBuild", { version: release.version }) : game.tagline}
      </h2>
      <p class="mt-4 leading-8 text-muted">
        {release ? release.summary[locale] : game.summary}
      </p>
      <p class="mt-4 text-sm leading-6 text-muted">{game.legalNotes}</p>
      <div class="mt-7 flex flex-wrap gap-3">
        {
          release ? (
            <>
              <CTAButton href="/en/download" label={t(locale, "game.downloadsCta")} />
              <CTAButton href="/en/devlog" label={t(locale, "game.devlogCta")} variant="secondary" />
              <CTAButton href="/en/#games" label={t(locale, "game.backToGamesCta")} variant="secondary" />
            </>
          ) : (
            <>
              <CTAButton href={game.primaryCta.href} label={game.primaryCta.label} />
              <CTAButton href={game.secondaryCta.href} label={game.secondaryCta.label} variant="secondary" />
            </>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
