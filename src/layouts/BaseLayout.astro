---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { site, type Locale } from "@/data/site";
import "@/styles/global.css";

interface Props {
  locale?: Locale;
  title: string;
  description: string;
  showHeader?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { locale = "zh-CN", title, description, showHeader = true, jsonLd } = Astro.props;
const currentPath = Astro.url.pathname;
const canonical = new URL(currentPath, site.baseUrl).toString();
const zhPath = currentPath.startsWith("/en") ? currentPath.replace(/^\/en/, "/zh-CN") : currentPath;
const enPath = currentPath.startsWith("/zh-CN") ? currentPath.replace(/^\/zh-CN/, "/en") : currentPath;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="zh-CN" href={new URL(zhPath, site.baseUrl).toString()} />
    <link rel="alternate" hreflang="en" href={new URL(enPath, site.baseUrl).toString()} />
    <meta property="og:site_name" content={site.name[locale]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {jsonLd && <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    {showHeader && <Header locale={locale} />}
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
